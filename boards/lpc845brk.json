{
  "build": {
    "core": "lpc8xx",
    "cpu": "cortex-m0plus",
    "extra_flags": "-DCPU_LPC845M301JBD48 -D__LPC845__ -DLPC845 -DARDUINO_LPC845BRK",
    "f_cpu": "30000000L",
    "ldscript": "$PROJECT_PACKAGES_DIR/framework-arduino-lpc8xx/linker_scripts/gcc/lpc845_flash.ld",
    "mcu": "lpc845",
    "variant": "lpc845brk"
  },
  "debug": {
    "jlink_device": "LPC845M301JBD48",
    "openocd_target": "lpc84x.cfg",
    "svd_path": "LPC845.svd"
  },
  "frameworks": [
    "arduino"
  ],
  "name": "NXP LPC845-BRK",
  "upload": {
    "maximum_ram_size": 16384,
    "maximum_size": 65536,
    "protocol": "cmsis-dap",
    "protocols": [
      "cmsis-dap",
      "jlink",
      "blackmagic",
      "isp"
    ]
  },
  "url": "https://www.nxp.com/design/microcontrollers-developer-resources/lpc845-breakout-board-for-lpc84x-family-mcus:LPC845-BRK",
  "vendor": "NXP"
}
